{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Thyself",
  "version": "0.1.0",
  "identifier": "com.thyself.app",
  "build": {
    "beforeDevCommand": "cp src-tauri/icons/icon-dev.icns src-tauri/icons/icon.icns 2>/dev/null; cp src-tauri/icons/icon-dev.icns src-tauri/target/debug/Contents/Resources/icon.icns 2>/dev/null; npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cp src-tauri/icons/icon-prod.icns src-tauri/icons/icon.icns 2>/dev/null; npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Thyself",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/jfru/thyself/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkzREU3ODYxQzg0QTRFNjYKUldSbVRrcklZWGpla3pVVzd6anF0bnYrTlg4WFJmZ1c5RUJuRHRyT2dnZ0MrOUxQamtCOHBmOGEK"
    }
  }
}
