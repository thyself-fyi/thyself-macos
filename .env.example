# Required
ANTHROPIC_API_KEY=sk-ant-...

# Your name (used in extraction prompts and synthesis)
THYSELF_SUBJECT_NAME=YourName

# Your email (used for Gmail is_from_me detection)
THYSELF_EMAIL=you@gmail.com

# Data directory — where thyself.db, sessions, and results are stored
# Default: ~/Library/Application Support/Thyself
# THYSELF_DATA_DIR=~/Library/Application Support/Thyself

# Optional: OpenAI key (for meditation generation)
# OPENAI_API_KEY=sk-...

# Optional: WhatsApp backup password (for extract_whatsapp.py)
# WA_BACKUP_PW=your-iphone-backup-password

# Optional: iPhone backup path (for WhatsApp extraction)
# THYSELF_IPHONE_BACKUP=~/Library/Application Support/MobileSync/Backup/YOUR-DEVICE-UUID

# Optional: macOS Contacts database path
# Find yours with: ls ~/Library/Application\ Support/AddressBook/Sources/
# THYSELF_CONTACTS_DB=~/Library/Application Support/AddressBook/Sources/YOUR-SOURCE-UUID/AddressBook-v22.abcddb

# Optional: Contacts annotation CSV
# THYSELF_CONTACTS_CSV=/path/to/contacts_for_annotation.csv

# Optional: Google Cloud project ID (for Gmail API)
# THYSELF_GCP_PROJECT=your-gcp-project-id

# Optional: Override the Claude model (default: claude-opus-4-6)
# THYSELF_MODEL=claude-opus-4-6
